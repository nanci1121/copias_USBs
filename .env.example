# Configuración de UUIDs de discos USB
# Para obtener los UUIDs de tus discos, ejecuta: sudo blkid
UUID_ORIGEN="tu-uuid-disco-origen-principal"
UUID_ORIGEN_ALT="tu-uuid-disco-origen-secundario"
UUID_DESTINO="tu-uuid-disco-destino-aqui"

# Puntos de montaje
MOUNT_ORIGEN="/media/usb_origen"
MOUNT_DESTINO="/media/usb_destino"

# Notificaciones (Opcional)
# NTFY_TOPIC="tu_tema_secreto_aqui"
